{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 430,
  "height": 420,

  "data": {
    "url": "students_country_2025_top20.csv"
  },

  "mark": {
    "type": "bar",
    "color": "#6FAF8F"
  },

  "encoding": {
    "y": {
      "field": "country",
      "type": "nominal",
      "title": "Source country",
      "sort": "-x"
    },

    "x": {
      "field": "enrolments",
      "type": "quantitative",
      "title": "International student enrolments in 2025",
      "axis": {
        "format": ","
      }
    },

    "tooltip": [
      {
        "field": "country",
        "type": "nominal",
        "title": "Country"
      },
      {
        "field": "enrolments",
        "type": "quantitative",
        "title": "Enrolments",
        "format": ","
      }
    ]
  }
}
