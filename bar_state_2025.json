{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 430,
  "height": 300,

  "data": {
    "url": "students_state_2025.csv"
  },

  "mark": {
    "type": "bar",
    "color": "#2F6DA3"
  },

  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "title": "State",
      "sort": "-x"
    },

    "x": {
      "field": "enrolments",
      "type": "quantitative",
      "title": "International student enrolments in 2025",
      "axis": {
        "format": ","
      }
    },

    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "enrolments",
        "type": "quantitative",
        "title": "Enrolments",
        "format": ","
      }
    ]
  }
}
